++	/* Disable VDM reception */
++	tmp = readl(pcie->base + PCIE_MISC_CTRL_1);
++	tmp &= ~PCIE_MISC_CTRL_1_EN_VDM_QOS_CONTROL_MASK;
++	writel(tmp, pcie->base + PCIE_MISC_CTRL_1);
++
++	return 0;
++}
